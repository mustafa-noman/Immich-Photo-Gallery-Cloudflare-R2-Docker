UPLOAD_LOCATION=E:/Immich/library
DB_DATA_LOCATION=postgres-data
TZ=Asia/Dhaka
IMMICH_VERSION=v2
DB_PASSWORD=GENERATE_A_RANDOM_ALPHANUMERIC_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

