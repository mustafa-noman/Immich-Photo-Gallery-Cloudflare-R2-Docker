UPLOAD_LOCATION=D:/Immich/library
DB_DATA_LOCATION=postgres-data
TZ=Asia/Dhaka
IMMICH_VERSION=v3
DB_PASSWORD=GENERATE_A_RANDOM_ALPHANUMERIC_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Cloudflare R2 values for the rclone mount container
R2_BUCKET_NAME=my-photo-gallery-immich
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
